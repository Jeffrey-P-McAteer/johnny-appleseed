<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <AssemblyName>JohnnyAppleseed</AssemblyName>
    <RootNamespace>JohnnyAppleseed</RootNamespace>
    <!-- Single-file publish with embedded native libs -->
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <!-- Suppress single-file IL stripping warnings from Raylib internals -->
    <SuppressTrimAnalysisWarnings>true</SuppressTrimAnalysisWarnings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Raylib-cs" Version="8.0.0" />
  </ItemGroup>

  <!--
    ══════════════════════════════════════════════════════════════════════════
    Build-time stamp: generates obj/.../BuildInfo.cs before CoreCompile with
    version (from version.txt), UTC timestamp, hostname, and git short hash.
    The file is in obj/ so it is never checked into version control.
    ══════════════════════════════════════════════════════════════════════════
  -->
  <Target Name="GenerateBuildInfo" BeforeTargets="CoreCompile">

    <!-- ── version from version.txt at repo root ─────────────────────────── -->
    <PropertyGroup>
      <_VersionFile>$(MSBuildThisFileDirectory)..\..\version.txt</_VersionFile>
    </PropertyGroup>
    <Error Condition="!Exists('$(_VersionFile)')"
           Text="version.txt not found — expected at $(_VersionFile)" />
    <PropertyGroup>
      <_BuildVersion>$([System.IO.File]::ReadAllText("$(_VersionFile)").Trim())</_BuildVersion>
    </PropertyGroup>

    <!-- ── UTC build timestamp ───────────────────────────────────────────── -->
    <PropertyGroup>
      <_BuildDate>$([System.DateTime]::UtcNow.ToString("yyyy-MM-dd HH:mm:ss")) UTC</_BuildDate>
    </PropertyGroup>

    <!-- ── hostname ──────────────────────────────────────────────────────── -->
    <Exec Command="hostname"
          ConsoleToMSBuild="true"
          IgnoreExitCode="true"
          StandardOutputImportance="low"
          StandardErrorImportance="low">
      <Output TaskParameter="ConsoleOutput" PropertyName="_BuildHostRaw" />
    </Exec>
    <PropertyGroup>
      <!-- Prefer 'hostname' output; fall back to env vars (CI / Windows) -->
      <_BuildHost Condition="'$(_BuildHostRaw)' != ''">$(_BuildHostRaw.Trim())</_BuildHost>
      <_BuildHost Condition="'$(_BuildHost)' == '' And '$(COMPUTERNAME)' != ''">$(COMPUTERNAME)</_BuildHost>
      <_BuildHost Condition="'$(_BuildHost)' == '' And '$(HOSTNAME)'    != ''">$(HOSTNAME)</_BuildHost>
      <_BuildHost Condition="'$(_BuildHost)' == ''">unknown</_BuildHost>
    </PropertyGroup>

    <!-- ── git short hash ────────────────────────────────────────────────── -->
    <Exec Command="git rev-parse --short HEAD"
          ConsoleToMSBuild="true"
          IgnoreExitCode="true"
          StandardOutputImportance="low"
          StandardErrorImportance="low">
      <Output TaskParameter="ConsoleOutput" PropertyName="_GitHashRaw" />
    </Exec>
    <PropertyGroup>
      <_GitHash Condition="'$(_GitHashRaw)' != ''">$(_GitHashRaw.Trim())</_GitHash>
      <_GitHash Condition="'$(_GitHash)' == ''">untracked</_GitHash>
    </PropertyGroup>

    <!-- ── write BuildInfo.cs to the intermediate output directory ──────── -->
    <MakeDir Directories="$(IntermediateOutputPath)" />
    <!-- Notes on MSBuild item escaping used here:
           %22 = "   %3B = ;   &lt; = <   &gt; = >
         MSBuild strips leading whitespace from Include values, so indentation
         is omitted — the C# compiler does not require it.
         Semicolons in code lines must be %3B or they split the item list.  -->
    <ItemGroup>
      <_BuildInfoLines Include="// &lt;auto-generated /&gt; - regenerated on every compile - do not edit" />
      <_BuildInfoLines Include="namespace JohnnyAppleseed%3B" />
      <_BuildInfoLines Include="static class BuildInfo {" />
      <_BuildInfoLines Include="public const string Version   = %22$(_BuildVersion)%22%3B" />
      <_BuildInfoLines Include="public const string BuildDate = %22$(_BuildDate)%22%3B" />
      <_BuildInfoLines Include="public const string BuildHost = %22$(_BuildHost)%22%3B" />
      <_BuildInfoLines Include="public const string GitHash   = %22$(_GitHash)%22%3B" />
      <_BuildInfoLines Include="}" />
    </ItemGroup>
    <WriteLinesToFile
      File="$(IntermediateOutputPath)BuildInfo.cs"
      Lines="@(_BuildInfoLines)"
      Overwrite="true"
      Encoding="UTF-8" />

    <!-- Make the generated file visible to CoreCompile -->
    <ItemGroup>
      <Compile Include="$(IntermediateOutputPath)BuildInfo.cs" />
    </ItemGroup>
  </Target>

  <!--
    ══════════════════════════════════════════════════════════════════════════
    Native library overrides
    ══════════════════════════════════════════════════════════════════════════
    Override / supplement native libs for RIDs missing from or improved beyond
    the Raylib-cs NuGet package.  Files are only included when present on disk,
    so a clean checkout builds fine with the NuGet defaults.

    linux-x64 (Wayland):
      Produced by `uv run scripts/setup-native-libs.py linux-wayland`.
      Replaces the NuGet X11-only lib with a GLFW 3.4 multi-platform build
      (both X11 and Wayland backends compiled in).
      The sentinel .wayland-enabled is read at runtime by Platform/LinuxDisplay.cs
      to decide whether to prefer Wayland over X11/XWayland.

    linux-arm64, win-arm64:
      Produced by `uv run scripts/setup-native-libs.py linux-arm64 win-arm64`.
      RIDs absent from the Raylib-cs NuGet package.
  -->
  <ItemGroup>
    <!-- linux-x64 Wayland lib overrides the NuGet X11-only copy -->
    <Content Include="runtimes\linux-x64\native\libraylib.so"
             Condition="Exists('runtimes\linux-x64\native\libraylib.so')">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      <CopyToPublishDirectory>Always</CopyToPublishDirectory>
    </Content>
    <!-- Sentinel read by LinuxDisplay.WaylandLibPresent() at runtime -->
    <Content Include="runtimes\linux-x64\native\.wayland-enabled"
             Condition="Exists('runtimes\linux-x64\native\.wayland-enabled')">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      <CopyToPublishDirectory>Always</CopyToPublishDirectory>
      <Link>.wayland-enabled</Link>
    </Content>

    <!-- linux-arm64: cross-compiled by setup-native-libs.py -->
    <Content Include="runtimes\linux-arm64\native\libraylib.so"
             Condition="Exists('runtimes\linux-arm64\native\libraylib.so')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </Content>

    <!-- win-arm64: cross-compiled by setup-native-libs.py -->
    <Content Include="runtimes\win-arm64\native\raylib.dll"
             Condition="Exists('runtimes\win-arm64\native\raylib.dll')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </Content>
  </ItemGroup>

  <!--
    After NuGet stages native assets for publish, overwrite linux-x64's
    libraylib.so with our Wayland-capable version when present.
  -->
  <Target Name="OverrideWaylandLib"
          AfterTargets="ResolveNativeAssets"
          Condition="'$(RuntimeIdentifier)' == 'linux-x64' And
                     Exists('$(MSBuildThisFileDirectory)runtimes\linux-x64\native\libraylib.so')">
    <Message Text="Using Wayland-capable libraylib.so override" Importance="high" />
    <ItemGroup>
      <ResolvedNativeAssetToPublish Remove="@(ResolvedNativeAssetToPublish)"
        Condition="'%(Filename)%(Extension)' == 'libraylib.so'" />
      <ResolvedNativeAssetToPublish Include="$(MSBuildThisFileDirectory)runtimes\linux-x64\native\libraylib.so">
        <DestinationSubPath>libraylib.so</DestinationSubPath>
      </ResolvedNativeAssetToPublish>
    </ItemGroup>
  </Target>

</Project>
